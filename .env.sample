# App
APP_NAME=TEA PTS
APP_URL=http://localhost:3000

# JWT
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=
# Uma lista de audiências separadas por vírgula. Veja: https://datatracker.ietf.org/doc/html/rfc7519#section-4.1.3.
